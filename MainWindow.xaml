<Window
    x:Class="WindowsCustomizer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid x:Name="AppTitleBar" Grid.Row="0">
            <TextBlock Text="Windows Customizer" VerticalAlignment="Center" Margin="16,0,0,0" Style="{ThemeResource CaptionTextBlockStyle}"/>
        </Grid>

        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        PaneTitle="Windows Customizer"
                        IsPaneToggleButtonVisible="True"
                        ItemInvoked="NavView_ItemInvoked"
                        Loaded="NavView_Loaded">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="home" Icon="Home"/>
                <NavigationViewItemSeparator/>
                <NavigationViewItemHeader Content="Customization"/>
                <NavigationViewItem Content="Bloatware Removal" Tag="bloatware" Icon="Delete"/>
                <NavigationViewItem Content="Program Installer" Tag="installer" Icon="Download"/>
                <NavigationViewItem Content="Explorer" Tag="explorer" Icon="Folder"/>
                <NavigationViewItem Content="Search Bar" Tag="search" Icon="Find"/>
                <NavigationViewItem Content="Invasive Services" Tag="services" Icon="BlockContact"/>
                <NavigationViewItem Content="Defender Killswitch" Tag="defender" Icon="Admin"/>
                <NavigationViewItemSeparator/>
                <NavigationViewItemHeader Content="Advanced"/>
                <NavigationViewItem Content="Custom MSC" Tag="msc" Icon="Library"/>
                <NavigationViewItem Content="Registry" Tag="registry" Icon="Repair"/>
                <NavigationViewItem Content="Windhawk UI" Tag="windhawk" Icon="Highlight"/>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Padding="12"/>
        </NavigationView>
    </Grid>
</Window>