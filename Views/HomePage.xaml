<Page
    x:Class="WindowsCustomizer.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
            <TextBlock Text="Welcome to Windows Customizer" Style="{StaticResource HeaderTextBlockStyle}"/>
            <TextBlock Text="Select a module from the left to begin." HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
