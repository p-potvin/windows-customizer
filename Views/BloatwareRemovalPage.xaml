<Page
    x:Class="WindowsCustomizer.Views.BloatwareRemovalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WindowsCustomizer.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Bloatware Removal" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock
                Text="Select the UWP apps you want to uninstall. Be careful, some apps might be required by the system."
                Style="{ThemeResource BodyTextBlockStyle}" TextWrapping="Wrap" />
        </StackPanel>

        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.AppxPackages}"
            SelectionMode="None"
            IsItemClickEnabled="False">
            <ListView.Header>
                <Grid Padding="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" IsChecked="{x:Bind ViewModel.IsAllSelected, Mode=TwoWay}"
                              VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="Application Name" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="Publisher" FontWeight="SemiBold" VerticalAlignment="Center" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:AppxPackage">
                    <Grid Padding="12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                  VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind Version}" FontSize="12" Opacity="0.7" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind Publisher}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ProgressRing Grid.Row="1" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="50" Height="50"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />

        <Button Grid.Row="2" Content="Uninstall Selected" HorizontalAlignment="Right" Margin="0,12,0,0"
                Style="{ThemeResource AccentButtonStyle}" />
    </Grid>
</Page>