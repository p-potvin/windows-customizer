<Page
    x:Class="WindowsCustomizer.Views.InvasiveServicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WindowsCustomizer.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Invasive Services &amp; Telemetry" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock
                Text="Toggle various telemetry and cloud-integration features built into Windows."
                Style="{ThemeResource BodyTextBlockStyle}" TextWrapping="Wrap" />
        </StackPanel>

        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Services}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:InvasiveService">
                    <Grid Padding="12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="{x:Bind Description}" Opacity="0.7" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <ToggleSwitch Grid.Column="1" 
                                      IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                      OnContent="Enabled" OffContent="Disabled"
                                      VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button Grid.Row="2"
                Content="Apply Changes"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                Command="{x:Bind ViewModel.ApplyChangesCommand}"
                Style="{ThemeResource AccentButtonStyle}" />

        <ProgressRing Grid.Row="1" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="50" Height="50"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Canvas.ZIndex="10" />
    </Grid>
</Page>
