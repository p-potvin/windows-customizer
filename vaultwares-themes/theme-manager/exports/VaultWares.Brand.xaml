<!-- /Themes/VaultWares.Brand.xaml -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- VaultWares Gold Edition -->
    <FontFamily x:Key="VaultFontFamily">Segoe UI Semilight</FontFamily>

    <!-- Core Colors -->
    <Color x:Key="VaultSlate">#4A5459</Color>
    <Color x:Key="VaultGold">#CC9B21</Color>
    <Color x:Key="VaultGoldMuted">#B78C1E</Color>
    <Color x:Key="VaultGoldLight">#E5C06A</Color>
    <Color x:Key="VaultPaper">#FDFCF7</Color>
    <Color x:Key="VaultInk">#002B36</Color>
    <Color x:Key="VaultCyan">#21B8CC</Color>
    <Color x:Key="VaultGreen">#4ECC21</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="VaultSlateBrush" Color="{StaticResource VaultSlate}" />
    <SolidColorBrush x:Key="VaultGoldBrush" Color="{StaticResource VaultGold}" />
    <SolidColorBrush x:Key="VaultPaperBrush" Color="{StaticResource VaultPaper}" />
    <SolidColorBrush x:Key="VaultInkBrush" Color="{StaticResource VaultInk}" />

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource VaultPaper}" />
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource VaultInk}" />
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource VaultGold}" />
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#FFFFFF" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <!-- Dark is slate, not pure black per STYLE.md -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource VaultSlate}" />
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#FDFCF7" />
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource VaultGold}" />
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#3A4246" />
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#3A4246" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>